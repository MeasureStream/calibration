      "b": { "siExp": 0, "si": [0, 0, 0, 0, -1, 1, 0, 0], "dsi": "\\per\\kelvin" },
      "c": { "siExp": 0, "si": [0, 0, 0, 0, -1, 1, 0, 0], "dsi": "\\per\\kelvin" },
      "d": { "siExp": 0, "si": [0, 0, 0, 0, -1, 1, 0, 0], "dsi": "\\per\\kelvin" }
    }
  },
  "metrology": {

    "evaluationFormula": "uB",
    "requiredInputs": ["uB"],

    "preprocessingFormula": "(d_in / (adcMax - d_in)) * rDivider",
    "preprocessingInputUnit": "\\one",
