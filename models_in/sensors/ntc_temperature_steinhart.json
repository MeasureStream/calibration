{
  "schemaVersion": "1.0.2",

  "modelName": "TemperatureSensorNTCSteinhart",

  "mpn": "NTCLP450E3",
  "manufacturer": "Vishay",
  "datasheet": "https://www.vishay.com/docs/29110/ntclp450e3.pdf",
  "templateId": 201,

  "type": "temperature",

  "usercomment_0": "The measurement are provided with the unit reported hereafter (namely 'unit')",
  "unit": "\\degreeCelsius",

  "usercomment_1": "elecUnit and elec array are relative to the reading values of the sensor, to be used along with the readingUncertainty parameters",
  "elecUnit": "\\one",

  "obsList": [
    "Results refer exclusively to the instrument identified in this certificate.",
    "Calibration is valid under the declared conditions and on the execution date.",
    "Reference temperature T_ref measured by PT100/Fluke 1502A (mean per step).",
    "Sensor temperature T_sensor measured by NTC via TMP126 ADC (mean per step)."
  ],
  "methodDescription": "GUM-compliant Ordinary Least Squares (OLS) Steinhart-Hart regression in the resistance domain. The raw NTC ADC reading D [LSB] is first converted to thermistor resistance R [Ω] using a voltage-divider chain declared in preprocessingFormula (R = D / (adcMax - D) * rDivider). The regression model is 1/T_K = a + b*ln(R) + c*(ln R)^3, where T_K is the absolute temperature. Sensor type-B uncertainty is computed per step via evaluationFormula (currently uB only). Hardware constants (rDivider, vRef, adcMax) are declared in preprocessingFormulaConstants and propagate as Type-B contributions. Uncertainty propagation follows ISO/IEC Guide 98-3 (GUM).",
  "calibrationFormula": "1/T_K = a + b*ln(R) + c*(ln R)^3,  R = D / (ADC_MAX - D) * rDivider",

  "ranges": {

    "phys": {
      "min": -40.0,
